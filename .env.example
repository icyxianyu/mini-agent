# LLM API 配置 (兼容 OpenAI 接口，也可用 DeepSeek / 通义千问 等)
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# 可选：自定义系统提示词
SYSTEM_PROMPT=你是一个编程助手，可以读写文件、帮助用户完成编程任务。

# 上下文注入：启动时自动收集项目信息注入到 LLM 的 system prompt
# 让 LLM 天然"知道项目长什么样"，减少手动描述的成本
ENABLE_CONTEXT_INJECTION=true

# 目录树收集配置（上下文注入用）
CONTEXT_DIR_DEPTH=3           # 目录树递归深度
CONTEXT_MAX_TOP_ENTRIES=30    # 根目录最大显示条目数
